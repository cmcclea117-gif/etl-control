<?xml version="1.0" encoding="UTF-8"?>
<!--
    web.example.config — IIS configuration template
    Copy to web.config and update the authorization users list.
    web.config is gitignored — never commit it.

    Authorization: replace DOMAIN\user1, DOMAIN\user2 etc. with your
    Active Directory accounts that should have access.
    Anonymous users are denied; all requests require Windows Authentication.
-->
<configuration>
    <system.webServer>
        <defaultDocument>
            <files>
                <clear />
                <add value="index.php" />
            </files>
        </defaultDocument>
        <security>
            <requestFiltering>
                <!-- Block direct access to PowerShell wrappers -->
                <fileExtensions>
                    <add fileExtension=".ps1" allowed="false" />
                </fileExtensions>
                <!-- Block direct access to config and includes directories -->
                <hiddenSegments>
                    <add segment="config" />
                    <add segment="includes" />
                </hiddenSegments>
            </requestFiltering>
            <authorization>
                <!-- Replace with your AD accounts -->
                <add accessType="Allow" users="DOMAIN\user1,DOMAIN\user2,DOMAIN\user3" />
                <remove users="*" roles="" verbs="" />
                <add accessType="Deny" users="?" />
            </authorization>
        </security>
        <httpErrors errorMode="Detailed" />
    </system.webServer>
</configuration>
